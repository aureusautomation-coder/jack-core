# ============================================================================
# Aria AI — Client Deployment Config
# Copy this file and fill in for each new client
# Usage: bash deploy-aria.sh clients/clientname.env
# ============================================================================

# ── Client Info (REQUIRED) ───────────────────────────────────────────────────
CLIENT_NAME="Jasmine Toh Financial Advisory"
BOT_NAME="Aria"
OWNER_DISPLAY_NAME="Jasmine"
ADDRESS_AS="Jasmine"
PERSONALITY="Warm & friendly, professional, bilingual (English/Mandarin)"
TIMEZONE="Asia/Singapore"

# ── API Keys (REQUIRED) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-PASTE_CLIENT_KEY_HERE"
REPLICATE_API_TOKEN=""  # Optional — needed for English TTS (Kokoro) and image generation

# ── Telegram (fill after creating bot via @BotFather) ────────────────────────
OWNER_TELEGRAM_ID=""       # Client's Telegram user ID
TELEGRAM_BOT_TOKEN=""      # From @BotFather

# ── Model ────────────────────────────────────────────────────────────────────
CLAUDE_MODEL="anthropic/claude-haiku-4-5-20251001"  # haiku=cheap, sonnet=smart

# ── Server (auto-detected if blank) ─────────────────────────────────────────
SERVER_HOST=""             # e.g. https://clientdomain.com — auto-detected if blank
GATEWAY_PASSWORD=""        # Auto-generated if blank

# ── Google Workspace (configured post-deploy via gog CLI) ────────────────────
GOG_KEYRING_PASSWORD="aria2026"

# ── Ports (defaults work for single-client VPS) ─────────────────────────────
OPENCLAW_PORT=18789
BROWSER_PORT=18800
MEDIA_PORT=18801
PDF_PORT=18802
CALENDAR_PORT=18803
TTS_PORT=18804
UTILS_PORT=18805
COMMS_PORT=18806
SMART_NOTES_PORT=18809
EXPENSE_TRACKER_PORT=18810
DAILY_BRIEFING_PORT=18811
WEEKLY_REPORT_PORT=18812
WEBCHAT_PORT=18808
